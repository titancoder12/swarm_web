---
import BaseLayout from "../layouts/BaseLayout.astro";

const gallery = [
  {
    src: "/images/IMG_8198.heic.png",
    alt: "Swarm robot photo.",
    title: "Robot Build"
  },
  {
    src: "/images/IMG_8082.HEIC.png",
    alt: "Swarm robot photo.",
    title: "Prototype View"
  },
  {
    src: "/images/IMG_8233.HEIC.png",
    alt: "Swarm robot photo.",
    title: "Robot Design"
  },
  {
    src: "/images/IMG_8261.HEIC.png",
    alt: "Swarm robot photo.",
    title: "Working Overtime"
  }
];

const videos = [
  {
    title: "Observing Ants",
    src: "/video/IMG_6892.MOV"
  },
  {
    title: "Making the Robots",
    src: "/video/IMG_8084.MOV"
  },
  {
    title: "Robots in Action",
    src: "/video/IMG_8275.mov"
  },
  {
    title: "Mission Control",
    src: "/video/IMG_8276.MOV"
  }
];
---

<BaseLayout
  title="Artificial Collective Intelligence"
  description="A visual showcase of carpenter ant-inspired swarm robotics, digital pheromones, physical robots, and the supporting code."
>
  <main>
    <section class="hero album-hero">
      <div class="hero-backdrop"></div>
      <div class="hero-noise"></div>
      <div class="container album-hero-grid">
        <div class="album-copy">
          <div class="hero-chip">GVRSF 2026 · Swarm Robotics · Photo Showcase</div>
          <h1>Artificial collective intelligence, shown through the robot, the diagrams, and the build.</h1>
          <p class="hero-text">
            This project explores carpenter ant-inspired swarm robotics through
            decentralized control, digital pheromones, Mission Control, and a
            physical robot platform. This page is a simple visual album with the
            core media and a direct link to the code.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#gallery">View gallery</a>
            <a class="button button-ghost" href="#videos">See video slots</a>
            <a class="button button-ghost" href="https://github.com/titancoder12/Ants" target="_blank" rel="noreferrer">
              <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M12 .5C5.65.5.5 5.66.5 12.03c0 5.1 3.3 9.42 7.89 10.95.58.11.79-.25.79-.56 0-.27-.01-1.17-.02-2.11-3.21.7-3.89-1.37-3.89-1.37-.53-1.34-1.28-1.7-1.28-1.7-1.04-.72.08-.71.08-.71 1.15.08 1.75 1.18 1.75 1.18 1.02 1.76 2.69 1.25 3.35.96.1-.74.4-1.25.72-1.53-2.56-.29-5.25-1.28-5.25-5.72 0-1.26.45-2.3 1.18-3.11-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.19a10.9 10.9 0 0 1 5.77 0c2.2-1.5 3.17-1.19 3.17-1.19.62 1.59.23 2.76.11 3.05.73.81 1.18 1.85 1.18 3.11 0 4.45-2.69 5.42-5.26 5.71.41.36.78 1.06.78 2.15 0 1.55-.01 2.79-.01 3.17 0 .31.21.68.8.56 4.58-1.53 7.88-5.85 7.88-10.95C23.5 5.66 18.35.5 12 .5Z"/>
              </svg>
              <span>View GitHub</span>
            </a>
          </div>
        </div>

        <figure class="hero-photo-frame">
          <img class="hero-photo" src="/images/IMG_8198.heic.png" alt="Hero photo of the assembled swarm robot platform." />
        </figure>
      </div>
    </section>

    <section id="gallery" class="section">
      <div class="container">
        <div class="album-heading">
          <p class="eyebrow">Gallery</p>
        </div>

        <div class="album-grid">
          {gallery.map((item) => (
            <figure class="album-card">
              <img class="album-image" src={item.src} alt={item.alt} />
              <figcaption class="album-caption">
                <strong>{item.title}</strong>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="videos" class="section section-dark">
      <div class="container">
        <div class="album-heading">
          <p class="eyebrow">Videos</p>
        </div>

        <div class="video-strip">
          {videos.map((video) => (
            <article class="video-slot">
              <video class="video-preview-player" src={video.src} controls preload="metadata" playsinline></video>
              <div class="video-copy">
                <strong>{video.title}</strong>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-accent">
      <div class="container">
        <div class="repo-panel">
          <div>
            <p class="eyebrow">Code</p>
            <h2>Open-source repo, full project.</h2>
            <p class="section-copy">
              The full implementation, training stack, firmware, Mission
              Control, and deployment work live in the repository.
            </p>
          </div>
          <div class="hero-actions">
            <a class="button button-primary" href="https://github.com/titancoder12/Ants" target="_blank" rel="noreferrer">
              <svg class="button-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M12 .5C5.65.5.5 5.66.5 12.03c0 5.1 3.3 9.42 7.89 10.95.58.11.79-.25.79-.56 0-.27-.01-1.17-.02-2.11-3.21.7-3.89-1.37-3.89-1.37-.53-1.34-1.28-1.7-1.28-1.7-1.04-.72.08-.71.08-.71 1.15.08 1.75 1.18 1.75 1.18 1.02 1.76 2.69 1.25 3.35.96.1-.74.4-1.25.72-1.53-2.56-.29-5.25-1.28-5.25-5.72 0-1.26.45-2.3 1.18-3.11-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.19a10.9 10.9 0 0 1 5.77 0c2.2-1.5 3.17-1.19 3.17-1.19.62 1.59.23 2.76.11 3.05.73.81 1.18 1.85 1.18 3.11 0 4.45-2.69 5.42-5.26 5.71.41.36.78 1.06.78 2.15 0 1.55-.01 2.79-.01 3.17 0 .31.21.68.8.56 4.58-1.53 7.88-5.85 7.88-10.95C23.5 5.66 18.35.5 12 .5Z"/>
              </svg>
              <span>Open GitHub Repository</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
