---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Artificial Collective Intelligence",
  description = "A swarm robotics project exploring stigmergy, reinforcement learning, digital pheromones, and sim-to-real transfer."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1118" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
