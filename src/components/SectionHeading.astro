---
interface Props {
  eyebrow: string;
  title: string;
  body?: string;
  align?: "left" | "center";
}

const { eyebrow, title, body = "", align = "left" } = Astro.props;
---

<div class={`section-heading ${align === "center" ? "section-heading-center" : ""}`}>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {body && <p class="section-copy">{body}</p>}
</div>
